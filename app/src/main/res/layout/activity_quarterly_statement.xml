<?xml version="1.0" encoding="utf-8"?>
<!--
    Nome do Arquivo: activity_quarterly_statement.xml
    Projeto: Controle de Ponto Eletrônico

    Descrição:
    Layout da tela de extrato trimestral. Utiliza ConstraintLayout para estruturação base,
    AppBarLayout para a barra de ferramentas superior e NestedScrollView para o conteúdo
    dinâmico do histórico mensal, garantindo scroll em dispositivos menores.

    Histórico de Modificações:
    Versão   Data        Autor           Descrição
    _________________________________________________________________________________________
    3.0.8    Jun/2026    Walter R. C.    Ajuste de margens e padding para evitar sobreposição
                                         da Status Bar e melhorar o alinhamento visual.
    2.1.0    Jun/2026    Walter R. C.    Estruturação inicial com AppBarLayout e NestedScrollView.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".QuarterlyStatementActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Extrato Trimestral"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:id="@+id/layoutQuarterlyMonths"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Conteúdo preenchido dinamicamente via QuarterlyStatementActivity -->
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>