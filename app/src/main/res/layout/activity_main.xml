<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Meu Ponto"
            app:titleTextColor="@color/white">

            <!-- Indicador visual de status de backup na nuvem -->
            <ImageView
                android:id="@+id/ivCloudStatus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:contentDescription="Status do Backup"
                android:src="@drawable/ic_sync"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:alpha="0.7"
                android:textColor="@color/white"
                android:textSize="10sp"
                tools:text="v1.7.9" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Card de Saldo Trimestral e Mensal (Grade Densa com Headers) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSaldoTrimestre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F3E5F5"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Linha de Cabeçalhos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Saldo"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:textColor="#6A1B9A"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Meta"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:textColor="#6A1B9A"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Falta"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:textColor="#6A1B9A"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="%"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:textColor="#6A1B9A"
                            android:alpha="0.7" />
                    </LinearLayout>

                    <!-- Linha 1: Trimestre -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="Tri"
                            android:textSize="12sp"
                            android:textColor="#4A148C"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTrimestreSaldo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00h 00m"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#4A148C"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTrimestreMeta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00h"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#4A148C"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTrimestreFalta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00h 00m"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#4A148C"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTrimestrePercent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#4A148C"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Linha 2: Mês -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="Mês"
                            android:textSize="12sp"
                            android:textColor="#7B1FA2"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMesSaldo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00h 00m"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMesMeta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00h"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMesFalta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="00h 00m"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvMesPercent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/tvSuggestedDaily"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textSize="12sp"
                            tools:text="Sugestão de extras/dia: 00h 00m" />

                        <TextView
                            android:id="@+id/tvExtrapolatedOvertime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textSize="12sp"
                            tools:text="Projeção final do mês: +00h 00m" />

                        <TextView
                            android:id="@+id/tvMonthlyBusinessDays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:textColor="#7B1FA2"
                            android:textSize="12sp"
                            tools:text="Dias úteis: 22 | Restantes: 10" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSaldoTrimestre">

                <ImageButton
                    android:id="@+id/btnPreviousDay"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Dia anterior"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Quinta-feira, 10/10/2023" />

                <ImageButton
                    android:id="@+id/btnNextDay"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Próximo dia"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="?attr/colorPrimary" />

                <ImageButton
                    android:id="@+id/btnToday"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Ir para hoje"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="?attr/colorPrimary" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/layoutDate">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Entrada -->
                    <TextView
                        android:id="@+id/lblClockIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entrada:"
                        android:textSize="17sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvClockIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblClockIn"
                        app:layout_constraintStart_toEndOf="@id/barrierLabels"
                        android:layout_marginStart="16dp"/>

                    <!-- Início Intervalo -->
                    <TextView
                        android:id="@+id/lblBreakStart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Início Intervalo:"
                        android:textSize="17sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lblClockIn" />

                    <TextView
                        android:id="@+id/tvBreakStart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblBreakStart"
                        app:layout_constraintStart_toEndOf="@id/barrierLabels"
                        android:layout_marginStart="16dp"/>

                    <!-- Fim Intervalo -->
                    <TextView
                        android:id="@+id/lblBreakEnd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Fim Intervalo:"
                        android:textSize="17sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lblBreakStart" />

                    <TextView
                        android:id="@+id/tvBreakEnd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblBreakEnd"
                        app:layout_constraintStart_toEndOf="@id/barrierLabels"
                        android:layout_marginStart="16dp"/>

                    <!-- Saída -->
                    <TextView
                        android:id="@+id/lblClockOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Saída:"
                        android:textSize="17sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lblBreakEnd" />

                    <TextView
                        android:id="@+id/tvClockOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblClockOut"
                        app:layout_constraintStart_toEndOf="@id/barrierLabels"
                        android:layout_marginStart="16dp"/>

                    <androidx.constraintlayout.widget.Barrier
                        android:id="@+id/barrierLabels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:barrierDirection="end"
                        app:constraint_referenced_ids="lblClockIn,lblBreakStart,lblBreakEnd,lblClockOut,lblTotalWorked,lblDailyOvertime" />

                    <View
                        android:id="@+id/separator"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="#EEEEEE"
                        app:layout_constraintTop_toBottomOf="@id/lblClockOut" />

                    <!-- Total Trabalhado -->
                    <TextView
                        android:id="@+id/lblTotalWorked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Total Trabalhado:"
                        android:textSize="17sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/separator" />

                    <TextView
                        android:id="@+id/tvTotalWorked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00h 00m"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblTotalWorked"
                        app:layout_constraintStart_toEndOf="@id/barrierLabels"
                        android:layout_marginStart="16dp"/>

                    <!-- Hora Extra Diária -->
                    <TextView
                        android:id="@+id/lblDailyOvertime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Hora Extra:"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lblTotalWorked" />

                    <TextView
                        android:id="@+id/tvDailyOvertime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00h 00m"
                        android:textColor="@android:color/holo_green_dark"
                        android:textSize="15sp"
                        app:layout_constraintBaseline_toBaselineOf="@id/lblDailyOvertime"
                        app:layout_constraintStart_toEndOf="@id/barrierLabels"
                        android:layout_marginStart="16dp"
                        tools:text="+01h 20m" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressWork"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:trackCornerRadius="4dp"
                        app:trackThickness="8dp"
                        android:progress="0"
                        android:max="480"
                        app:layout_constraintTop_toBottomOf="@id/lblDailyOvertime" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPrediction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#E0F2F1"
                app:cardCornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardStatus">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvPrediction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Saída Estimada: --:--"
                        android:textAlignment="center"
                        android:textColor="#00695C"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRemaining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAlignment="center"
                        android:textColor="#00897B"
                        android:textSize="13sp"
                        tools:text="Faltam 02h 30m" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPunch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:padding="16dp"
                android:text="Registrar Ponto"
                app:icon="@drawable/ic_fingerprint"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:layout_constraintTop_toBottomOf="@id/cardPrediction" />

            <TextView
                android:id="@+id/tvTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:alpha="0.7"
                android:text="Jornada: 8h | Pausa: 2h"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnPunch" />

            <!-- Status do último backup na nuvem -->
            <TextView
                android:id="@+id/tvLastBackupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:alpha="0.6"
                android:gravity="center"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                app:layout_constraintTop_toBottomOf="@id/tvTarget"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="Nuvem: Sucesso em 10/10/2023 10:00 (100 registros salvos)\nArquivo: backup.csv" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>